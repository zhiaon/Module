[URL Rewrite]
# 七猫广告配置接口
^https:\/\/api-cfg\.wtzw\.com\/v\d\/(reward|adv|splash|offline-adv|operation)\/ _ reject
# 七猫书店推送/配置
^https:\/\/api-bc\.wtzw\.com\/api\/v\d\/(book-store\/config|book-store\/push-book|operation|search\/dispose) _ reject
# 七猫提现广告
^https:\/\/xiaoshuo\.wtzw\.com\/api\/v\d\/withdraw\/init _ reject
# 七猫红包任务
^https:\/\/api-gw\.wtzw\.com\/welf\/app\/v\d\/task\/red-packet _ reject
# 七猫章节复制广告
^https:\/\/cdn\.wtzw\.com\/bookimg\/free\/api\/v\d\/reader\/reader-copy-paragraph-all\.json _ reject
# 字节穿山甲 / 头条广告物料
^https:\/\/sf3-fe-tos\.pglstatp-toutiao\.com\/obj\/ad-pattern\/ _ reject
# pangolin 广告 SDK
^https?:\/\/.+\.pangolin-sdk-toutiao\.com\/api\/ad\/union\/sdk\/(get_ads|stats|settings|config)\/ _ reject
# snssdk 广告
^https?:\/\/.+\.snssdk\.com\/api\/ad\/union\/sdk\/(get_ads|stats|settings|config|reward_video)\/ _ reject
# 广告素材
^https?:\/\/p(6|9)-ad-sign\.byteimg\.com\/.* _ reject

[MITM]
hostname = %APPEND% *.wtzw.com, *.gdt.qq.com, *.pangolin-sdk-toutiao.com, *.pglstatp-toutiao.com, *.snssdk.com, *.bytegecko.com, *.toutiaocloud.com, *.toutiaocloud.net, *.byteimg.com, *.kuaishou.com, *.kwad.net, *.kwaizt.com, *.zijieapi.com, *.bdurl.net, *.ugsdk.cn, *.mobads.baidu.com, *.fqnovel.com
