#!name=七猫小说去广告 V2
#!desc=七猫小说去广告 V2：拦截开屏/章内广告/底部横幅/听书广告/悬浮窗！覆盖 wtzw 全域 + gdt(腾讯广点通) + pangolin(穿山甲) + snssdk(字节) 广告链路。内嵌 Script 双重拦截。
#!author=Codex
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/SevenCat.png

[Script]
# ===== 响应体去广告 =====
http-response ^https?:\/\/api-cfg\.wtzw\.com\/v\d\/(reward|adv|splash|offline-adv|operation)\/ requires-body=true,timeout=10,script-path=qimao_block.js,tag=七猫-广告配置
http-response ^https?:\/\/api-bc\.wtzw\.com\/api\/v\d\/(book-store\/config|book-store\/push-book|operation|search\/dispose) requires-body=true,timeout=10,script-path=qimao_block.js,tag=七猫-书店广告
http-response ^https?:\/\/xiaoshuo\.wtzw\.com\/api\/v\d\/user\/my-center\? requires-body=true,timeout=10,script-path=qimao_block.js,tag=七猫-个人中心
http-response ^https?:\/\/xiaoshuo\.wtzw\.com\/api\/v\d\/withdraw\/init requires-body=true,timeout=10,script-path=qimao_block.js,tag=七猫-提现
http-response ^https?:\/\/api-gw\.wtzw\.com\/welf\/app\/v\d\/task\/red-packet requires-body=true,timeout=10,script-path=qimao_block.js,tag=七猫-红包任务
http-response ^https?:\/\/cdn\.wtzw\.com\/bookimg\/free\/api\/v\d\/reader\/reader-copy-paragraph-all\.json requires-body=true,timeout=10,script-path=qimao_block.js,tag=七猫-章节复制

# ===== 穿山甲 / 头条广告拦截 =====
http-response ^https?:\/\/.*\.pglstatp-toutiao\.com\/obj\/ad-pattern\/ requires-body=true,timeout=10,script-path=qimao_block.js,tag=七猫-头条广告
http-response ^https?:\/\/.*\.pangolin-sdk-toutiao\.com\/api\/ad\/union\/sdk\/get_ads\/ requires-body=true,timeout=10,script-path=qimao_block.js,tag=七猫-穿山甲
http-response ^https?:\/\/.*\.snssdk\.com\/api\/ad\/union\/sdk\/get_ads\/ requires-body=true,timeout=10,script-path=qimao_block.js,tag=七猫-snssdk广告

[Script Body (qimao_block.js)]
var body = $response.body;
try {
  var obj = JSON.parse(body);
  if (obj) {
    if (obj.data && Array.isArray(obj.data)) obj.data = [];
    if (obj.ad_list && Array.isArray(obj.ad_list)) obj.ad_list = [];
    if (obj.ads && Array.isArray(obj.ads)) obj.ads = [];
    if (obj.ad_count !== undefined) obj.ad_count = 0;
    if (obj.total !== undefined) obj.total = 0;
    if (obj.cards) obj.cards = [];
    if (obj.creatives) obj.creatives = [];
    if (obj.func_area && Array.isArray(obj.func_area)) obj.func_area = obj.func_area.filter(function(f) { return f && f.name && (f.name.indexOf('广告') < 0 && f.name.indexOf('ad') < 0 && f.type !== 'advertisement'); });
    if (obj.welfare_center) obj.welfare_center = null;
    if (obj.task_list) obj.task_list = [];
    if (obj.red_packet) obj.red_packet = null;
  }
  $done({body: JSON.stringify(obj)});
} catch (e) {
  $done({});
}

[Script Body (qimao_request.js)]
$done({});

